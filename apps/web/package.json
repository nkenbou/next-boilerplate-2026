{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "run-p -l -c --aggregate-output dev:*",
    "dev:next": "next dev",
    "dev:storybook": "storybook dev -p 6006",
    "dev:tcm": "tcm -p '**/*.module.css' -w ./app",
    "build": "next build",
    "start": "next start",
    "test": "run-p -l -c --aggregate-output lint unit",
    "unit": "vitest run",
    "lint": "run-p -l -c --aggregate-output lint:*",
    "lint:eslint": "eslint . --max-warnings 0",
    "lint:stylelint": "stylelint '**/*.css'",
    "lint:prettier": "prettier --check .",
    "lint:tsc": "tsc -p . --noEmit",
    "lint:tcm": "tcm -p '**/*.module.css' -l ./app",
    "fix": "run-p -l -c --aggregate-output fix:*",
    "fix:eslint": "pnpm lint:eslint --fix",
    "fix:stylelint": "pnpm lint:stylelint --fix",
    "fix:prettier": "pnpm lint:prettier --write",
    "vrt:reset": "rm -rf ./vrt/actual ./vrt/diff",
    "vrt:compare": "reg-cli ./vrt/actual ./vrt/expected ./vrt/diff -J ./vrt/out.json -R ./vrt/index.html -M 0.01",
    "vrt:approve": "pnpm vrt:compare -U"
  },
  "imports": {
    "#actions/*": "./app/_actions/*.ts",
    "#components/*": "./app/_components/*/index.tsx",
    "#lib/*": "./app/_lib/*.ts",
    "#lib/session": {
      "storybook": "./app/_lib/session.mock.ts",
      "default": "./app/_lib/session.ts"
    },
    "#lib/dal": {
      "storybook": "./app/_lib/dal.mock.ts",
      "default": "./app/_lib/dal.ts"
    }
  },
  "dependencies": {
    "@app/command-domain": "workspace:*",
    "@app/command-interface-adapter-if": "workspace:*",
    "@app/command-interface-adapter-impl": "workspace:*",
    "@app/query": "workspace:*",
    "@app/infrastructure": "workspace:*",
    "@app/ui": "workspace:*",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/themes": "^3.3.0",
    "jose": "^5.2.0",
    "next": "16.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reflect-metadata": "^0.2.1",
    "server-only": "^0.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@app/eslint-config": "workspace:*",
    "@app/stylelint-config": "workspace:*",
    "@app/typescript-config": "workspace:*",
    "@storybook/addon-docs": "10.2.16",
    "@storybook/addon-links": "10.2.16",
    "@storybook/addon-vitest": "10.2.16",
    "@storybook/nextjs-vite": "10.2.16",
    "@storybook/test": "^8.6.15",
    "@storycap-testrun/browser": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "22.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/browser": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.19.0",
    "eslint-plugin-storybook": "10.2.16",
    "jsdom": "^28.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.1.0",
    "reg-cli": "^0.18.14",
    "storybook": "10.2.16",
    "stylelint": "^16.2.1",
    "typed-css-modules": "^0.9.1",
    "typescript": "^5.5.3",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
