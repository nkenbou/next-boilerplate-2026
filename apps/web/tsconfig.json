{
  "extends": "@app/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*",
    ".storybook/**/*",
    "next-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
