# E2E test environment variables
# Copy this file to .env.e2e.local and fill in the values

# PostgreSQL connection string — e2e schema must be specified here so that                                                                                                                                                              
# both the web server and the test fixtures use the same schema                                                                                                                                                                         
DATABASE_URL=postgresql://postgres:password@localhost:5432/app?schema=e2e 

# Base URL of the web app under test
BASE_URL=http://localhost:3000

# Admin credentials (must match the seeded user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
