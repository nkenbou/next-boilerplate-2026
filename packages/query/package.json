{
  "name": "@app/query",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./processors": "./src/processors.ts",
    "./dto": "./src/dto.ts"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json",
    "test": "run-p -l -c --aggregate-output lint unit",
    "unit": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "lint": "run-p -l -c --aggregate-output lint:*",
    "lint:eslint": "eslint . --max-warnings 0",
    "lint:prettier": "prettier --check .",
    "lint:tsc": "tsc -p . --noEmit",
    "fix": "run-s fix:prettier fix:eslint",
    "fix:eslint": "pnpm lint:eslint --fix",
    "fix:prettier": "pnpm lint:prettier --write"
  },
  "devDependencies": {
    "@app/eslint-config": "workspace:*",
    "@app/typescript-config": "workspace:*",
    "@jest/globals": "^30.0.0",
    "@quramy/jest-prisma": "^1.8.2",
    "@quramy/jest-prisma-core": "^1.8.2",
    "@quramy/jest-prisma-node": "^1.8.2",
    "@quramy/prisma-fabbrica": "^2.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "22.12.0",
    "eslint": "^9.19.0",
    "jest": "^30.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "@app/db": "workspace:*",
    "@app/infrastructure": "workspace:*",
    "reflect-metadata": "^0.2.1",
    "server-only": "^0.0.1",
    "tsyringe": "^4.8.0"
  }
}
